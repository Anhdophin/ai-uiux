:root{
  --bg:#edf1ff;
  --panel:#ffffff;
  --ink:#101828;
  --muted:#667085;
  --line:rgba(16,24,40,.08);
  --blue:#2f6bff;
  --blue-2:#5c85ff;
  --accent:#f3b12f;
  --shadow:0 18px 48px rgba(38,55,99,.12);
  --radius-xl:28px;
  --radius-lg:22px;
  --radius-md:16px;
  --radius-sm:12px;
}
*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--bg);color:var(--ink);font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}
body{min-height:100vh}
a{color:var(--blue)}
button,input,select{font:inherit}
code{background:rgba(16,24,40,.05);padding:.1rem .35rem;border-radius:8px}
.app-shell{max-width:1180px;margin:0 auto;padding:16px 16px 180px}
.brand-header,.site-footer{background:rgba(255,255,255,.72);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.8);box-shadow:var(--shadow)}
.brand-header{display:flex;align-items:center;justify-content:space-between;border-radius:24px;padding:16px 18px;margin-bottom:18px}
.brand-copy{display:flex;gap:14px;align-items:center}
.brand-mark{width:78px;height:78px;border-radius:22px;display:grid;place-items:center;overflow:hidden;flex:0 0 auto}
.brand-mark img{display:block;width:100%;height:100%;object-fit:contain}
.eyebrow{margin:0 0 4px;font-size:.75rem;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:.08em}
.brand-header h1,.detail-content h2,.reader-title-group h2{margin:0;font-size:40px}
.brand-sub,.muted{color:var(--muted)}
.small{font-size:.85rem}
.page-stack{display:grid;gap:24px;margin-bottom:24px}
.screen{display:none;gap:18px}
.screen.active{display:grid}
.phone-panel{background:var(--panel);border-radius:32px;box-shadow:var(--shadow);padding:18px}
.search-stack{display:grid;gap:10px}
.search-box{display:flex;align-items:center;gap:10px;background:#f7f8fb;border-radius:16px;padding:14px 16px}
.search-meta{margin:0;padding-left:4px}
.search-box input{border:none;background:transparent;width:100%;outline:none}
.search-icon{font-size:1rem;color:var(--muted)}
.home-filter-stack{display:grid;gap:14px;padding-top:2px}
.home-filter-group{display:grid;gap:8px}
.home-filter-head{display:flex;align-items:center;justify-content:flex-start;gap:10px;padding-left:4px;color:#344054;font-size:.84rem}
.home-filter-head-split{justify-content:space-between}
.home-filter-row{display:flex;gap:8px;overflow-x:auto;padding-bottom:2px;scrollbar-width:none}
.home-filter-row::-webkit-scrollbar{display:none}
.home-filter-chip{border:none;border-radius:999px;padding:9px 12px;background:#f4f6fb;color:#344054;font-weight:700;white-space:nowrap;cursor:pointer;flex:0 0 auto}
.home-filter-chip.active{background:#dce8ff;color:#234eb7}
.home-filter-clear{padding:0;font-size:.82rem}

.hero-card{display:flex;flex-direction:column;gap:16px;align-items:flex-start;background:linear-gradient(180deg,#fff,#f8fbff)}
.pill-button,.primary-button,.icon-button,.link-button,.nav-item,.drawer-tab{border:none;cursor:pointer}
.pill-button{padding:12px 18px;border-radius:999px;background:#eef3ff;color:var(--blue);font-weight:700}
.small-pill{padding:10px 12px;font-size:.88rem}
.primary-button{padding:14px 20px;border-radius:18px;background:var(--blue);color:#fff;font-weight:700;box-shadow:0 10px 24px rgba(47,107,255,.26)}
.section-head{display:flex;align-items:end;justify-content:space-between;margin-bottom:14px;gap:16px}
.section-head h3,.section-head h2{margin:0}
.section-head.tight{align-items:center}
.link-button{background:transparent;color:var(--blue);font-weight:700}
.book-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.book-strip{display:grid;grid-auto-flow:column;grid-auto-columns:minmax(180px,220px);gap:14px;overflow-x:auto;padding-bottom:4px;scroll-snap-type:x proximity}
.book-strip > *{scroll-snap-align:start}
.home-library-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.book-card{background:#fff;border:none;padding:0;text-align:left;cursor:pointer}
.cover-card,.detail-cover{border-radius:24px;overflow:hidden;box-shadow:0 16px 40px rgba(17,24,39,.14);position:relative;background:#101828}
.cover-card{aspect-ratio:3/4;color:#fff}
.cover-media,.detail-cover-media{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center center;transform:scale(1.01)}
.cover-card::before,.detail-cover::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 20%,rgba(255,255,255,.22),transparent 35%),linear-gradient(180deg,transparent 30%,rgba(0,0,0,.62) 100%);z-index:1}
.cover-card .title-layer,.detail-cover .title-layer{position:absolute;left:0;right:0;bottom:0;z-index:2;padding:14px;color:#fff}
.cover-card h4,.detail-cover h3{margin:.1rem 0 .35rem;font-size:1rem;line-height:1.1}
.cover-card p,.detail-cover p{margin:0;font-size:.78rem;color:rgba(255,255,255,.88)}
.book-price{position:absolute;top:12px;right:12px;z-index:2;background:rgba(255,255,255,.85);color:#1d2939;border-radius:999px;padding:4px 10px;font-size:.72rem;font-weight:700}
.card-caption{padding:10px 4px 0}
.card-caption h4{margin:0;font-size:.92rem;line-height:1.2;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.card-caption p{margin:4px 0 0;font-size:.78rem;color:var(--muted)}
.library-toolbar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin:4px 0 14px}
.library-toolbar p{margin:0}
.library-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
.library-grid.is-search-results{grid-template-columns:1fr}
.detail-panel{padding:0;overflow:hidden;position:relative}
.detail-back{position:absolute;top:16px;left:16px;z-index:3}
.detail-cover-wrap{padding:18px 18px 0}
.detail-cover{aspect-ratio:4/5;min-height:320px}
.detail-content{padding:18px;display:grid;gap:12px}
.meta-strip{display:flex;gap:12px;flex-wrap:wrap;color:var(--muted);font-size:.92rem}
.detail-description{margin:0;color:#344054;line-height:1.75}
.actions-row{display:flex;gap:12px;flex-wrap:wrap}
.reader-panel{padding:0;position:relative;overflow:visible}
.reader-hero{background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(255,255,255,.9));border-bottom:1px solid var(--line)}
.reader-toolbar{display:flex;gap:10px;align-items:center;padding:16px;background:transparent}
.reader-hero-actions{display:flex;gap:8px;align-items:center}
.reader-title-group{min-width:0;flex:1}
.reader-title-group h2,.reader-title-group p{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.reader-sticky-wrap{
  position:-webkit-sticky;
  position:sticky;
  top:0;
  z-index:999;
}
.reader-sticky-controls{
  display:flex;
  gap:10px;
  align-items:center;
  justify-content:space-between;
  padding:10px 16px 14px;
  background:rgba(255,255,255,.96);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  border-top:1px solid rgba(16,24,40,.04);
  border-bottom:1px solid var(--line);
  pointer-events:auto;
}
.reader-sticky-group{display:flex;align-items:center;gap:10px}
.reader-sticky-controls .icon-button{min-width:44px}
.reader-sticky-controls .icon-button:disabled{opacity:.45;cursor:not-allowed}
.icon-button{width:42px;height:42px;border-radius:14px;background:#f7f8fb;color:#1d2939;font-size:1.1rem;display:grid;place-items:center}
.reader-layout{display:grid;position:relative;min-width:0;max-width:100%;overflow-x:hidden}
.toc-drawer,.settings-drawer{
  position:absolute;
  top:calc(100% + 8px);
  right:12px;
  left:12px;
  z-index:1000;
  border:1px solid var(--line);
  border-radius:20px;
  padding:14px 16px;
  max-height:min(60vh,420px);
  overflow:auto;
  background:#fbfcff;
  box-shadow:0 18px 48px rgba(38,55,99,.18);
}
.drawer-head h3{margin:.2rem 0 .9rem}
.drawer-tabs{display:flex;gap:8px;margin-bottom:12px}
.drawer-tab{padding:10px 12px;border-radius:12px;background:#eef1f8;color:#475467;font-weight:700}
.drawer-tab.active{background:#dce8ff;color:#234eb7}
.drawer-panel{display:none;gap:12px}
.drawer-panel.active{display:grid}
.toc-list,.bookmark-list{display:grid;gap:8px}
.toc-item,.bookmark-item{display:flex;align-items:center;gap:10px;width:100%;padding:10px 12px;border:none;border-radius:14px;background:transparent;text-align:left;cursor:pointer}
.bookmark-item{background:#f4f6fb}
.toc-item.active,.toc-item:hover,.bookmark-item:hover{background:#edf3ff}
.toc-badge{min-width:22px;height:22px;border-radius:999px;background:#dbe6ff;color:#335db8;font-size:.74rem;font-weight:800;display:grid;place-items:center}
.bookmark-copy{display:grid;gap:2px;min-width:0;flex:1}
.bookmark-copy strong,.bookmark-copy span{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.reader-article{padding:24px 18px 36px;min-height:60vh;scroll-behavior:smooth;position:relative;z-index:1;min-width:0;max-width:100%;overflow-x:hidden}
.reader-content{min-height:50vh;min-width:0;max-width:100%}
.settings-stack{display:grid;gap:14px}
.setting-note{margin:0;color:var(--muted);font-size:.84rem;line-height:1.55}
.setting-block{display:grid;gap:8px;color:#344054;font-weight:600}
.setting-block select,.setting-block input{width:100%;border:1px solid var(--line);border-radius:14px;padding:12px;background:#fff}
.bottom-nav{position:fixed;left:16px;right:16px;bottom:20px;display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:10px;background:rgba(255,255,255,.9);backdrop-filter:blur(18px);border-radius:22px;box-shadow:var(--shadow);z-index:20}
.nav-item{background:transparent;border-radius:16px;padding:10px 8px;color:var(--muted);display:grid;justify-items:center;gap:6px}
.nav-item.active{background:#eef3ff;color:var(--blue)}
.nav-icon{font-size:1.05rem}
.nav-label{font-size:.72rem;font-weight:700}

.search-result-card{display:grid;grid-template-columns:120px 1fr;gap:14px;align-items:start;padding:14px;border:none;border-radius:24px;background:#f8fbff;box-shadow:0 12px 28px rgba(38,55,99,.08);text-align:left;cursor:pointer}
.search-result-cover .cover-card{aspect-ratio:3/4}
.search-result-copy h3{margin:0 0 6px;font-size:1.05rem;line-height:1.25}
.search-result-section{margin:0 0 8px;font-weight:700;color:#1d2939}
.search-result-snippet{margin:0;color:#475467;line-height:1.6;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
.site-footer{margin-top:22px;border-radius:28px;padding:22px;display:grid;gap:18px}
.empty-state{padding:14px;border-radius:16px;background:#f4f6fb;color:var(--muted)}
@media (min-width: 720px){
  .app-shell{padding:24px 24px 120px}
  .page-stack{grid-template-columns:1.15fr .95fr .95fr;align-items:start}
  .screen-home.active,.screen-library.active,.screen-detail.active,.screen-reader.active{grid-column:1/-1}
  .screen-home.active{grid-template-columns:1fr 1fr 1fr;align-items:start}
  .search-panel{grid-column:1/2;grid-row:1}
  .hero-card{grid-column:1/2;grid-row:2}
  .new-books-panel{grid-column:2/4;grid-row:1/span 2}
  .home-library-panel{grid-column:1/-1;grid-row:3}
  .book-strip{grid-auto-columns:minmax(200px,240px)}
  .home-library-grid{grid-template-columns:repeat(6,minmax(0,1fr))}
  .library-grid{grid-template-columns:repeat(4,minmax(0,1fr))}
  .detail-panel{display:grid;grid-template-columns:.95fr 1.05fr;align-items:end}
  .detail-cover-wrap{padding:26px 26px 26px 34px}
  .detail-content{padding:28px 28px 28px 0}
  .reader-layout{min-height:65vh}
  .reader-article{padding:28px 28px 44px}
  .reader-sticky-controls{padding-inline:20px}
  .toc-drawer,.settings-drawer{
    width:min(360px, calc(100vw - 64px));
    left:auto;
    right:20px;
  }
  .search-result-card{grid-template-columns:140px 1fr}
  .bottom-nav{position:sticky;bottom:24px;max-width:460px;margin:28px auto 0}
  .site-footer{grid-template-columns:1.3fr 1fr}
}

.library-filters{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin:6px 0 12px}
.filter-field{display:grid;gap:6px;font-size:.82rem;font-weight:700;color:#344054}
.filter-field select{width:100%;border:1px solid var(--line);border-radius:14px;padding:12px;background:#fff;color:#1d2939}
.filter-chips{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 12px}
.filter-chip{border:none;border-radius:999px;padding:10px 14px;background:#f4f6fb;color:#344054;font-weight:700;cursor:pointer}
.filter-chip.active{background:#dce8ff;color:#234eb7}
.library-toolbar-actions{display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end}
.card-meta{margin-top:4px;color:#98a2b3;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
@media (max-width: 719px){.library-filters{grid-template-columns:1fr}}

.downloads-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin:0 0 14px}
.download-card{display:block}
.download-actions{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
.download-pill{padding-inline:12px}
.download-cover-fallback{display:grid;place-items:center;background:linear-gradient(135deg,#111827,#2956c4 52%,#73c6ff 110%);color:#fff;font-size:2rem;font-weight:800}
.download-cover-fallback span{letter-spacing:.08em}
