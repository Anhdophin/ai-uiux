{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "version",
    "locale",
    "fallback_locale",
    "entries"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "fallback_locale": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "label",
          "short",
          "long"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "short": {
            "type": "string"
          },
          "long": {
            "type": "string"
          },
          "tone": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}