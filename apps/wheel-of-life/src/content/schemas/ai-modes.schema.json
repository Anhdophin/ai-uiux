{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIModesSeedBundle",
  "type": "object",
  "required": ["version", "updated_at", "source_note", "modes"],
  "properties": {
    "version": {"type": "string"},
    "updated_at": {"type": "string"},
    "source_note": {"type": "string"},
    "modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "purpose", "allowed_actions", "disallowed_actions"],
        "properties": {
          "id": {"type": "string"},
          "purpose": {"type": "string"},
          "allowed_actions": {"type": "array", "items": {"type": "string"}},
          "disallowed_actions": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}