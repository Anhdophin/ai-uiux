{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FeelingsSeedBundle",
  "type": "object",
  "required": ["version", "updated_at", "source_note", "feelings"],
  "properties": {
    "version": {"type": "string"},
    "updated_at": {"type": "string"},
    "source_note": {"type": "string"},
    "feelings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "subtitle", "prompt"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "subtitle": {"type": "string"},
          "prompt": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}